generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  playerName          String?
  uid                 String?   @unique
  rank                String?
  kdRatio             Float?
  winRate             Float?
  totalMatches        Int?      @default(0)
  totalWins           Int?      @default(0)
  totalKills          Int?      @default(0)
  favoriteCharacter   String?
  favoriteWeapon      String?
  region              String?   @default("Asia")
  avatarUrl           String?
  isPremium           Boolean   @default(false)
  premiumExpiresAt    DateTime?
  searchesUsedToday   Int       @default(0)
  searchesResetAt     DateTime  @default(now())
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  emailVerifyToken    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  guildMembers   GuildMember[]
  chatMessages   ChatMessage[]
  matches        Match[]
  subscription   Subscription?
  affiliateClicks AffiliateClick[]
  guildsOwned    Guild[]          @relation("GuildOwner")
}

model Guild {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String
  region      String   @default("Asia")
  description String?
  logoUrl     String?
  inviteCode  String   @unique @default(cuid())
  level       Int      @default(1)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User          @relation("GuildOwner", fields: [ownerId], references: [id])
  members  GuildMember[]
  messages ChatMessage[]
}

model GuildMember {
  id       String   @id @default(cuid())
  userId   String
  guildId  String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  channel   String   @default("general")
  userId    String
  guildId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  status      String   @default("UPCOMING")
  region      String   @default("Asia")
  prizePool   String?
  date        DateTime
  maxTeams    Int      @default(16)
  currentTeams Int     @default(0)
  managerName String?
  managerEmail String?
  description String?
  createdAt   DateTime @default(now())

  contacts TournamentContact[]
}

model TournamentContact {
  id           String   @id @default(cuid())
  tournamentId String
  name         String
  email        String
  message      String?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Match {
  id        String   @id @default(cuid())
  userId    String
  kills     Int      @default(0)
  assists   Int      @default(0)
  damage    Int      @default(0)
  placement Int      @default(1)
  won       Boolean  @default(false)
  mode      String   @default("Battle Royale")
  playedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String   @unique
  plan              String   @default("premium")
  status            String   @default("active")
  provider          String
  providerId        String?
  amount            Int
  currency          String   @default("INR")
  startDate         DateTime @default(now())
  endDate           DateTime
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaitlistEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  page      String
  createdAt DateTime @default(now())
}

model AffiliateClick {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  url       String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
